{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/dustfeather/dustfeather/.github/schemas/classified.schema.json",
  "title": "Profile badge classification",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "generated_at", "rows", "currently_exploring"],
  "properties": {
    "schema_version": { "const": 1 },
    "generated_at":   { "type": "string", "format": "date-time" },
    "rows": {
      "type": "array",
      "minItems": 7,
      "maxItems": 7,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["category", "pills", "bullet"],
        "properties": {
          "category": {
            "type": "string",
            "pattern": "^[A-Z0-9 &/+-]{2,32}$"
          },
          "pills": {
            "type": "array",
            "minItems": 3,
            "maxItems": 6,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 16,
              "pattern": "^[A-Za-z0-9 ./+#-]+$"
            }
          },
          "bullet": {
            "type": "object",
            "additionalProperties": false,
            "required": ["title", "body"],
            "properties": {
              "title": { "type": "string", "minLength": 1, "maxLength": 80 },
              "body":  { "type": "string", "minLength": 1, "maxLength": 600 }
            }
          }
        }
      }
    },
    "currently_exploring": { "type": "string", "minLength": 1, "maxLength": 200 }
  }
}
